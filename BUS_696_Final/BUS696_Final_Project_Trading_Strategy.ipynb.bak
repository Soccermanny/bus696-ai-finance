    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"⚠️  ALIGNMENT VALIDATION: Signal vs. Target (Look-Ahead Bias Test)\")\n",
    "print(\"=\"*70)\n",
    "print(\"Verifying that signals are properly lagged relative to target returns...\")\n",
    "print()\n",
    "\n",
    "# Spot-check alignment on a sample\n",
    "validation_idx = 100\n",
    "if validation_idx < len(feat_df):\n",
    "    sample = feat_df.iloc[validation_idx:validation_idx+5]\n",
    "    \n",
