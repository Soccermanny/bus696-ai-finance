    "### Signal 3: Low Volatility Anomaly\n",
    "**Hypothesis:** Frazzini & Pedersen (2014) — leverage-constrained investors bid up high-beta  \n",
    "stocks, leaving low-volatility stocks underpriced. Signal = negative 6-month realized volatility."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_low_vol_signal(returns_monthly, lookback=6):\n",
    "    \"\"\"Negative 6-month realized volatility — buy low-vol, sell high-vol.\"\"\"\n",
    "    vol_6m = returns_monthly.rolling(lookback).std()\n",
    "    # Negate: lower vol = higher signal (buy)\n",
    "    low_vol_raw = -vol_6m\n",
    "    # Cross-sectional z-score\n",
    "    low_vol_z = low_vol_raw.sub(low_vol_raw.mean(axis=1), axis=0)\\\n",
    "                           .div(low_vol_raw.std(axis=1), axis=0)\n",
    "    return low_vol_z\n",
    "\n",
    "sig_low_vol = compute_low_vol_signal(returns_monthly_clean)\n",
    "\n",
    "print(f\"Low-vol signal shape: {sig_low_vol.shape}\")\n",
    "print(f\"Cross-sectional std (should ~1.0): {sig_low_vol.std(axis=1).mean():.3f}\")"
   ]
  },
