   "source": [
    "## Section 7: Performance & Risk Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def performance_summary(returns_series, name, rf_rate=0.04):\n",
    "    \"\"\"Annualized performance metrics.\"\"\"\n",
    "    r = returns_series.dropna()\n",
    "    ann_ret  = (1 + r.mean())**12 - 1\n",
    "    ann_vol  = r.std() * np.sqrt(12)\n",
    "    rf_monthly = rf_rate / 12\n",
    "    sharpe   = (r.mean() - rf_monthly) / r.std() * np.sqrt(12)\n",
    "    \n",
    "    # Max drawdown\n",
    "    cumret = (1 + r).cumprod()\n",
    "    rolling_max = cumret.cummax()\n",
    "    drawdown = (cumret - rolling_max) / rolling_max\n",
    "    max_dd = drawdown.min()\n",
    "    \n",
    "    calmar = ann_ret / abs(max_dd) if max_dd != 0 else np.nan\n",
    "    \n",
    "    return pd.Series({\n",
    "        'Strategy': name,\n",
    "        'Ann. Return': f\"{ann_ret:.1%}\",\n",
    "        'Ann. Vol': f\"{ann_vol:.1%}\",\n",
    "        'Sharpe': f\"{sharpe:.2f}\",\n",
    "        'Max Drawdown': f\"{max_dd:.1%}\",\n",
    "        'Calmar': f\"{calmar:.2f}\",\n",
    "        'Months': len(r)\n",
    "    })\n",
    "\n",
    "# Align all series to same index\n",
    "common_idx = perf.index\n",
    "\n",
    "perf_table = pd.DataFrame([\n",
    "    performance_summary(perf['net_return'],                               'XGBoost Strategy (Net)'),\n",
    "    performance_summary(perf['gross_return'],                            'XGBoost Strategy (Gross)'),\n",
    "    performance_summary(ew_returns.reindex(common_idx).dropna(),         'Equal-Weight Baseline'),\n",
    "    performance_summary(mom_only_returns.reindex(common_idx).dropna(),   'Pure Momentum Baseline'),\n",
    "])\n",
    "\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"PERFORMANCE SUMMARY (OOS Walk-Forward Only)\")\n",
    "print(\"=\"*70)\n",
    "print(perf_table.to_string(index=False))\n",
    "print()\n",
    "print(\"NOTE: Sharpe > 2.0 gets penalized by rubric — target 0.5–1.5 range.\")"
   ]
  },
