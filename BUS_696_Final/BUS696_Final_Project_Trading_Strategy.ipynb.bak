    "BACKTEST_START = '2018-01-01'\n",
    "\n",
    "# Strategy parameters\n",
    "TOP_N  = 30   # long legs\n",
    "BOT_N  = 30   # short legs (for signal IC calc)\n",
    "LONG_ONLY = True  # long-only portfolio for rubric compatibility\n",
    "\n",
    "print(f\"Setup complete. Backtest window: {BACKTEST_START} → {END_DATE}\")"
   ]
