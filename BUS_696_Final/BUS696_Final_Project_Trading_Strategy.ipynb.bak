    "    # Try Wikipedia archive + current list as best-effort approach\n",
    "    try:\n",
    "        # Get current constituents\n",
    "        current = get_sp500_tickers()[0]\n",
    "        print(f\"Current S&P 500 constituents: {len(current)} stocks\")\n",
    "        \n",
    "        # Try to fetch historical constituents from alternate source\n",
    "        # Using Quandl WIKI database (free tier) or other sources\n",
    "        try:\n",
    "            # Alternative: Use constituents history from a cached source\n",
    "            # For production, use: https://www.constituents.com/ or\n",
    "            # SEC EDGAR screening (all 10-K filers from 2015-2024)\n",
    "            \n",
    "            print(\"⚠️  Full historical constituents require premium data source\")\n",
    "            print(\"   Recommended: constituents.com, Refinitiv, or FactSet\")\n",
    "            print(\"   Using current list with 5% survivorship bias adjustment...\")\n",
    "            \n",
    "            # As compromise: add some known delisted stocks that were in S&P 500\n",
