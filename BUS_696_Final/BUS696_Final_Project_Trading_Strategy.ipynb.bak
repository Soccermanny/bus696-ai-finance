    "            manual_signal = sig_momentum_z.loc[date_val, ticker_val]\n",
    "            matches = \"✓\" if abs(manual_signal - signal_mom) < 0.01 else \"✗ MISMATCH\"\n",
    "            print(f\"{matches} {date_val.date()} | {ticker_val:6s} | Signal={signal_mom:+.3f} | Target={target_val:+.4f}\")\n",
    "    \n",
    "    print(\"\\n✓ Alignment check complete. If all show ✓, signals are properly lagged.\")\n",
    "    print(\"  If any show ✗, there may be off-by-one errors in the feature matrix.\")\n",
    "else:\n",
    "    print(\"Feature matrix too small for alignment validation\")\n"
   ]
