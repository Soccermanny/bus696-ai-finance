   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 3: IC Analysis — Signal Validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_ic(signal, forward_returns, min_obs=50):\n",
    "    \"\"\"\n",
    "    Spearman rank IC (Information Coefficient) between signal at t\n",
    "    and forward return at t+1.\n",
    "    \"\"\"\n",
    "    ic_series = []\n",
    "    # Forward returns: shift -1 (next month's return)\n",
    "    fwd_ret = forward_returns.shift(-1)\n",
    "    \n",
    "    common_idx = signal.index.intersection(fwd_ret.index)\n",
    "    \n",
    "    for date in common_idx:\n",
    "        s = signal.loc[date].dropna()\n",
    "        r = fwd_ret.loc[date].dropna()\n",
    "        common = s.index.intersection(r.index)\n",
    "        if len(common) < min_obs:\n",
    "            continue\n",
    "        rho, pval = stats.spearmanr(s[common], r[common])\n",
    "        ic_series.append({'date': date, 'IC': rho, 'pval': pval})\n",
    "    \n",
    "    return pd.DataFrame(ic_series).set_index('date')\n",
    "\n",
    "print(\"Computing ICs for all signals (this may take a minute)...\")\n",
    "\n",
    "ic_results = {}\n",
    "signals = {\n",
    "    'Momentum (12-1m)' : sig_momentum_z,\n",
    "    'Insider Net-Buy'  : sig_insider,\n",
    "    'Low Volatility'   : sig_low_vol,\n",
    "    'Earnings Quality' : sig_quality,\n",
    "}\n",
    "\n",
    "for name, sig in signals.items():\n",
    "    ic_df = compute_ic(sig, returns_monthly_clean)\n",
    "    ic_results[name] = ic_df\n",
    "    mean_ic = ic_df['IC'].mean()\n",
    "    tstat   = mean_ic / (ic_df['IC'].std() / np.sqrt(len(ic_df)))\n",
    "    print(f\"  {name:25s}  IC={mean_ic:+.4f}  t={tstat:+.2f}  n={len(ic_df)}\")\n",
    "\n",
    "print(\"\\nThresholds: IC > 0.05 = meaningful | IC > 0.10 = very strong | t > 2.0 = significant\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── IC Decay Test (bonus alt data requirement) ─────────────────────────────────\n",
    "def compute_ic_decay(signal, returns_monthly, lags=[1, 2, 4, 8]):\n",
    "    \"\"\"IC at multiple forward lags — signals should decay (else look-ahead bias).\"\"\"\n",
    "    results = {}\n",
    "    for lag in lags:\n",
    "        fwd = returns_monthly.shift(-lag)\n",
    "        ics = []\n",
    "        for date in signal.index:\n",
    "            try:\n",
    "                s = signal.loc[date].dropna()\n",
    "                r = fwd.loc[date].dropna()\n",
    "                common = s.index.intersection(r.index)\n",
    "                if len(common) < 30:\n",
    "                    continue\n",
    "                rho, _ = stats.spearmanr(s[common], r[common])\n",
    "                ics.append(rho)\n",
    "            except Exception:\n",
    "                continue\n",
    "        results[f'Lag {lag}m'] = np.mean(ics)\n",
    "    return pd.Series(results)\n",
    "\n",
    "print(\"\\nIC Decay by Forward Horizon:\")\n",
    "print(\"(Well-behaved signal: IC should decrease with longer lag)\")\n",
    "print()\n",
    "for name, sig in signals.items():\n",
    "    decay = compute_ic_decay(sig, returns_monthly_clean)\n",
    "    print(f\"  {name:25s}  \" + '  '.join([f\"{k}:{v:+.4f}\" for k,v in decay.items()]))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 4: XGBoost Cross-Sectional Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build feature matrix ──────────────────────────────────────────────────────\n",
    "\n",
    "def build_feature_matrix(signals_dict, returns_monthly, macro_monthly):\n",
    "    \"\"\"\n",
    "    Stack all signals into a (date, ticker, features) long DataFrame.\n",
    "    Target: next-month return (properly lagged).\n",
    "    \"\"\"\n",
    "    records = []\n",
    "    fwd_ret = returns_monthly.shift(-1)  # next-month return (prediction target)\n",
    "    \n",
    "    common_dates = returns_monthly.index[returns_monthly.index >= BACKTEST_START]\n",
    "    \n",
    "    for date in common_dates:\n",
    "        if date not in fwd_ret.index:\n",
    "            continue\n",
    "        \n",
    "        # Get macro regime scalar\n",
    "        macro_date = macro_monthly.index[macro_monthly.index <= date]\n",
    "        regime_scale = regime_scaler.loc[macro_date[-1]] if len(macro_date) > 0 else 1.0\n",
    "        vix_val      = macro_monthly.loc[macro_date[-1], 'VIX'] if len(macro_date) > 0 else 20.0\n",
    "        spread_val   = macro_monthly.loc[macro_date[-1], 'YIELD_SPREAD'] if len(macro_date) > 0 else 1.0\n",
    "        \n",
    "        # Build cross-section for this date\n",
    "        tickers = returns_monthly.columns\n",
    "        for ticker in tickers:\n",
    "            target = fwd_ret.loc[date].get(ticker, np.nan)\n",
    "            if pd.isna(target):\n",
    "                continue\n",
    "            \n",
    "            row = {\n",
    "                'date'    : date,\n",
    "                'ticker'  : ticker,\n",
    "                'target'  : target,\n",
    "                'regime_scale': regime_scale,\n",
    "                'vix'     : vix_val,\n",
    "                'yield_spread': spread_val,\n",
    "            }\n",
    "            \n",
    "            for sig_name, sig_df in signals_dict.items():\n",
    "                if date in sig_df.index and ticker in sig_df.columns:\n",
    "                    row[sig_name] = sig_df.loc[date, ticker]\n",
    "                else:\n",
    "                    row[sig_name] = np.nan\n",
    "            \n",
    "            records.append(row)\n",
    "    \n",
    "    return pd.DataFrame(records)\n",
    "\n",
    "SIGNAL_COLS = {\n",
    "    'momentum': sig_momentum_z,\n",
    "    'insider' : sig_insider,\n",
    "    'low_vol' : sig_low_vol,\n",
    "    'quality' : sig_quality,\n",
    "}\n",
    "\n",
    "print(\"Building feature matrix...\")\n",
    "feat_df = build_feature_matrix(SIGNAL_COLS, returns_monthly_clean, macro)\n",
    "print(f\"Feature matrix shape: {feat_df.shape}\")\n",
    "print(f\"Columns: {feat_df.columns.tolist()}\")\n",
    "print(f\"Missing signal values: {feat_df[list(SIGNAL_COLS.keys())].isna().mean().to_dict()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Walk-Forward Backtesting Engine ───────────────────────────────────────────\n",
    "# Expanding window | min 36-month train | 60 monthly folds\n",
    "\n",
    "FEATURE_COLS = list(SIGNAL_COLS.keys()) + ['vix', 'yield_spread']\n",
    "TARGET_COL   = 'target'\n",
    "MIN_TRAIN_MONTHS = 36\n",
    "\n",
    "def walk_forward_backtest(feat_df, feature_cols, target_col,\n",
    "                           min_train=MIN_TRAIN_MONTHS, top_n=TOP_N):\n",
    "    \"\"\"\n",
    "    Expanding-window walk-forward backtest.\n",
    "    Returns per-month portfolio returns and model metadata.\n",
    "    \"\"\"\n",
    "    feat_df = feat_df.copy()\n",
    "    feat_df['date'] = pd.to_datetime(feat_df['date'])\n",
    "    \n",
    "    all_dates = sorted(feat_df['date'].unique())\n",
    "    \n",
    "    results = []\n",
    "    models  = []\n",
    "    \n",
    "    for i, test_date in enumerate(all_dates):\n",
    "        # Training window: all data before test_date\n",
    "        train_data = feat_df[feat_df['date'] < test_date].copy()\n",
    "        test_data  = feat_df[feat_df['date'] == test_date].copy()\n",
    "        \n",
    "        # Minimum training window\n",
    "        n_train_months = len(feat_df[feat_df['date'] < test_date]['date'].unique())\n",
    "        if n_train_months < min_train:\n",
    "            continue\n",
    "        if len(test_data) < 20:\n",
    "            continue\n",
    "        \n",
    "        # Drop rows with any missing features\n",
    "        train_clean = train_data.dropna(subset=feature_cols + [target_col])\n",
    "        test_clean  = test_data.dropna(subset=feature_cols)\n",
    "        \n",
    "        if len(train_clean) < 200 or len(test_clean) < 10:\n",
    "            continue\n",
    "        \n",
    "        X_train = train_clean[feature_cols].values\n",
    "        y_train = train_clean[target_col].values\n",
    "        X_test  = test_clean[feature_cols].values\n",
    "        \n",
    "        # XGBoost model (tuned for cross-sectional ranking)\n",
    "        model = XGBRegressor(\n",
    "            n_estimators=100,\n",
    "            max_depth=3,\n",
    "            learning_rate=0.05,\n",
    "            subsample=0.8,\n",
    "            colsample_bytree=0.8,\n",
    "            reg_alpha=0.1,\n",
    "            reg_lambda=1.0,\n",
    "            random_state=SEED,\n",
    "            verbosity=0\n",
    "        )\n",
    "        model.fit(X_train, y_train)\n",
    "        \n",
    "        # Predict on test set\n",
    "        test_clean = test_clean.copy()\n",
    "        test_clean['predicted'] = model.predict(X_test)\n",
    "        \n",
    "        # Cross-sectional IC for this fold\n",
    "        fold_ic, _ = stats.spearmanr(\n",
    "            test_clean['predicted'], test_clean[target_col]\n",
    "        ) if len(test_clean) > 10 else (np.nan, np.nan)\n",
    "        \n",
    "        # Regime scalar\n",
    "        regime_scale_today = test_clean['regime_scale'].iloc[0]\n",
    "        \n",
    "        # Construct portfolio: long top_n, scale by regime\n",
    "        test_ranked = test_clean.sort_values('predicted', ascending=False)\n",
    "        \n",
    "        # Long-only top_n (equal weight within bucket)\n",
    "        longs = test_ranked.head(top_n)\n",
    "        port_return = longs[target_col].mean() * regime_scale_today\n",
    "        \n",
    "        # Feature importance\n",
    "        importances = dict(zip(feature_cols, model.feature_importances_))\n",
    "        \n",
    "        results.append({\n",
    "            'date'         : test_date,\n",
    "            'port_return'  : port_return,\n",
    "            'gross_return' : longs[target_col].mean(),\n",
    "            'n_train_months': n_train_months,\n",
    "            'n_stocks'     : len(test_clean),\n",
    "            'regime_scale' : regime_scale_today,\n",
    "            'fold_ic'      : fold_ic,\n",
    "            **importances\n",
    "        })\n",
    "        models.append(model)\n",
    "    \n",
    "    return pd.DataFrame(results).set_index('date'), models\n",
    "\n",
    "print(\"Running walk-forward backtest...\")\n",
    "wf_results, wf_models = walk_forward_backtest(feat_df, FEATURE_COLS, TARGET_COL)\n",
    "print(f\"\\nFolds completed: {len(wf_results)}\")\n",
    "print(f\"Date range: {wf_results.index[0].date()} → {wf_results.index[-1].date()}\")\n",
    "print(f\"Mean fold IC: {wf_results['fold_ic'].mean():.4f}\")"
   ]
  },
