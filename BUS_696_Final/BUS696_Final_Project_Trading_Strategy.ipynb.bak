   "source": [
    "### Signal 5: Macro Regime Filter (VIX + Yield Curve)\n",
    "**Hypothesis:** Market-wide risk regimes alter return distributions.  \n",
    "This is a **portfolio-level scaler**, not a stock-level rank signal.  \n",
    "**Regime scaling (from Week 4 Kelly lab):**  \n",
    "- VIX < 20: 100% allocation  \n",
    "- VIX 20–30: 75% allocation  \n",
    "- VIX > 30: 50% allocation  \n",
    "**Yield curve inversion (10Y–2Y < 0):** additional 10% haircut (recession warning)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Fetch VIX and yield curve from yfinance / FRED ───────────────────────────\n",
    "\n",
    "def fetch_macro_regime_data(start=START_DATE, end=END_DATE):\n",
    "    \"\"\"Download VIX and 10Y-2Y yield spread.\"\"\"\n",
    "    # VIX\n",
    "    vix = yf.download('^VIX', start=start, end=end, auto_adjust=True, progress=False)['Close']\n",
    "    vix.name = 'VIX'\n",
    "    \n",
    "    # 10Y Treasury (^TNX) and 2Y Treasury (^IRX)\n",
    "    tsy_10y = yf.download('^TNX', start=start, end=end, auto_adjust=True, progress=False)['Close'] / 10\n",
    "    tsy_2y  = yf.download('^IRX', start=start, end=end, auto_adjust=True, progress=False)['Close'] / 10\n",
    "    \n",
    "    macro = pd.DataFrame({'VIX': vix, 'TSY_10Y': tsy_10y, 'TSY_2Y': tsy_2y})\n",
    "    macro['YIELD_SPREAD'] = macro['TSY_10Y'] - macro['TSY_2Y']\n",
    "    macro['INVERTED'] = (macro['YIELD_SPREAD'] < 0).astype(int)\n",
    "    \n",
    "    # Monthly (end of month)\n",
    "    macro_monthly = macro.resample('ME').last()\n",
    "    return macro_monthly\n",
    "\n",
    "macro = fetch_macro_regime_data()\n",
    "print(f\"Macro data shape: {macro.shape}\")\n",
    "print(macro.tail())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_regime_scaler(macro_monthly):\n",
    "    \"\"\"VIX + yield curve regime scalar (0.5 to 1.0).\"\"\"\n",
    "    vix = macro_monthly['VIX']\n",
    "    inv = macro_monthly['INVERTED']\n",
    "    \n",
    "    # VIX-based scaling\n",
    "    scaler = pd.Series(1.0, index=vix.index)\n",
    "    scaler[vix >= 20] = 0.75\n",
    "    scaler[vix >= 30] = 0.50\n",
    "    \n",
    "    # Yield curve inversion haircut\n",
    "    scaler[inv == 1] *= 0.90\n",
    "    \n",
    "    return scaler.clip(0.50, 1.0)\n",
    "\n",
    "regime_scaler = compute_regime_scaler(macro)\n",
    "\n",
    "# Visualize regime\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 6), sharex=True)\n",
    "axes[0].plot(macro.index, macro['VIX'], color='crimson', linewidth=1.5)\n",
    "axes[0].axhline(20, color='orange', linestyle='--', alpha=0.7, label='VIX=20')\n",
    "axes[0].axhline(30, color='red',    linestyle='--', alpha=0.7, label='VIX=30')\n",
    "axes[0].set_ylabel('VIX'); axes[0].set_title('Macro Regime Indicators')\n",
    "axes[0].legend()\n",
    "axes[1].plot(macro.index, macro['YIELD_SPREAD'], color='navy', linewidth=1.5, label='10Y-2Y Spread')\n",
    "axes[1].axhline(0, color='red', linestyle='--', alpha=0.7)\n",
    "axes[1].fill_between(macro.index, macro['YIELD_SPREAD'], 0,\n",
    "                     where=macro['YIELD_SPREAD'] < 0, alpha=0.3, color='red', label='Inverted')\n",
    "axes[1].set_ylabel('Yield Spread (%)')\n",
    "axes[1].legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('macro_regime.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f\"\\nRegime scaler stats:\\n{regime_scaler.describe()}\")"
   ]
  },
