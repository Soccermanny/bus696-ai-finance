   "source": [
    "# ── Defense Contractor Contract Award Signal ──────────────────────────────────\n",
    "# Optional bonus: Build signal from SAM.gov contract data or simulated data\n",
    "\n",
    "DEFENSE_TICKERS = ['LMT', 'RTX', 'NOC', 'GD', 'BA', 'HII', 'LHX', 'LDOS']\n",
    "\n",
    "def compute_defense_contract_signal(prices_monthly, ic_target=0.025):\n",
    "    \"\"\"\n",
    "    Defense contractor contract award momentum signal.\n",
    "    \n",
    "    From Chapman FSM/MA course:\n",
    "    - Contract wins are leading indicators of future revenue (3-6 month lag)\n",
    "    - Government spending has seasonal patterns (Q3/Q4 fiscal year peaks)\n",
    "    - Signal: Rolling 3-month contract velocity (normalized)\n",
    "    \n",
    "    For production: Load from SAM.gov API or CSV export\n",
    "    For demo: Simulate with realistic IC ~0.025\n",
    "    \"\"\"\n",
    "    np.random.seed(SEED + 6)\n",
    "    \n",
    "    n_dates = len(prices_monthly)\n",
    "    n_cols = len(prices_monthly.columns)\n",
    "    \n",
    "    # Start with noise base\n",
    "    defense_raw = pd.DataFrame(\n",
    "        np.random.randn(n_dates, n_cols) * 0.6,\n",
    "        index=prices_monthly.index,\n",
    "        columns=prices_monthly.columns\n",
    "    )\n",
    "    \n",
    "    # Add seasonal pattern: Q3/Q4 (fiscal year) have higher government spending\n",
    "    quarters = prices_monthly.index.quarter\n",
    "    fiscal_weight = pd.Series(\n",
    "        np.where(quarters.isin([3, 4]), 0.5, 0.0),\n",
    "        index=prices_monthly.index\n",
    "    )\n",
    "    defense_raw = defense_raw.add(fiscal_weight / 2, axis=0)\n",
    "    \n",
    "    # Add weak correlation to past returns (contract awards precede revenue)\n",
    "    lagged_ret = returns_monthly_clean.shift(3).fillna(0)  # 3-month lag\n",
    "    defense_raw = (ic_target * lagged_ret / (lagged_ret.std().mean() + 1e-6) + \n",
    "                   defense_raw * (1 - ic_target))\n",
    "    \n",
    "    # Cross-sectional z-score for ranking\n",
    "    defense_z = defense_raw.sub(defense_raw.mean(axis=1), axis=0)\\\n",
    "                           .div(defense_raw.std(axis=1) + 1e-6, axis=0)\n",
    "    \n",
    "    return defense_z\n",
    "\n",
    "# Compute defense signal (only for defense tickers that exist in universe)\n",
    "defense_tickers_available = [t for t in DEFENSE_TICKERS if t in returns_monthly_clean.columns]\n",
    "print(f\"Defense tickers in universe: {len(defense_tickers_available)}\")\n",
    "print(f\"  {defense_tickers_available}\")\n",
    "\n",
    "# Compute full signal (will be NaN for non-defense tickers)\n",
    "sig_defense_raw = compute_defense_contract_signal(prices_monthly)\n",
    "\n",
    "# Align to full universe (NaN for non-defense stocks)\n",
    "sig_defense = sig_defense_raw.copy()\n",
    "for col in sig_defense.columns:\n",
    "    if col not in defense_tickers_available:\n",
    "        sig_defense[col] = np.nan\n",
    "\n",
    "print(f\"\\n✓ Defense contract signal computed: {sig_defense.shape}\")\n",
    "print(f\"  Expected IC: 0.02-0.03 (government procurement leading indicator)\")\n",
    "print(f\"  Non-null coverage (defense tickers): {sig_defense[defense_tickers_available].notna().mean().mean():.1%}\")"
