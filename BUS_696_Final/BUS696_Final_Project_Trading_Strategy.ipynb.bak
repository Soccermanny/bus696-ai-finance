    "## Section 10: Alt Data Bonus — LLM News Sentiment (Claude API)\n",
    "\n",
    "**Target:** IC analysis + signal decay test. Must show it adds value beyond price/volume."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── LLM Sentiment via Claude API ─────────────────────────────────────────────\n",
    "# Requires: pip install anthropic\n",
    "# API key: set ANTHROPIC_API_KEY environment variable\n",
    "\n",
    "import anthropic\n",
    "import json\n",
    "\n",
    "CLAUDE_CACHE = 'claude_sentiment_cache.json'\n",
    "\n",
    "def get_llm_sentiment_score(ticker, news_text, client):\n",
    "    \"\"\"\n",
    "    Use Claude to extract structured sentiment from news text.\n",
    "    Returns: sentiment score [-1, +1], confidence [0, 1], key catalysts.\n",
    "    \n",
    "    ADVANTAGE OVER ALPHA VANTAGE:\n",
    "    - Claude understands context (\"unexpectedly\" vs \"expected\" beats)\n",
    "    - Identifies specific catalysts: guidance raised, margin expansion, etc.\n",
    "    - Can separate operational sentiment from macro noise\n",
    "    - Detects hedging language that raw sentiment scores miss\n",
    "    \"\"\"\n",
    "    prompt = f\"\"\"Analyze this financial news about {ticker} and return ONLY a JSON object with:\n",
    "- \"sentiment\": number from -1.0 (very bearish) to +1.0 (very bullish)\n",
    "- \"confidence\": number from 0.0 to 1.0 (how confident you are)\n",
    "- \"catalysts\": list of 1-3 specific business drivers mentioned\n",
    "- \"time_horizon\": \"short\" (<1m), \"medium\" (1-6m), or \"long\" (>6m)\n",
    "\n",
    "News text: {news_text[:1000]}\n",
    "\n",
    "Return only the JSON, no explanation.\"\"\"\n",
    "\n",
    "    try:\n",
    "        message = client.messages.create(\n",
    "            model=\"claude-haiku-4-5-20251001\",  # Fast and cheap for batch processing\n",
    "            max_tokens=256,\n",
    "            messages=[{\"role\": \"user\", \"content\": prompt}]\n",
    "        )\n",
    "        response_text = message.content[0].text.strip()\n",
    "        # Parse JSON\n",
    "        result = json.loads(response_text)\n",
    "        return result\n",
    "    except Exception as e:\n",
    "        return {'sentiment': 0.0, 'confidence': 0.0, 'catalysts': [], 'error': str(e)}\n",
    "\n",
    "\n",
    "def fetch_news_and_score_sentiment(tickers, start_date, end_date, max_tickers=20):\n",
    "    \"\"\"\n",
    "    Demo: Use yfinance news feed + Claude API for sentiment.\n",
    "    Production: Use NewsAPI, Refinitiv, or Bloomberg for historical news.\n",
    "    \"\"\"\n",
    "    if os.path.exists(CLAUDE_CACHE):\n",
    "        print(\"Loading Claude sentiment cache...\")\n",
    "        with open(CLAUDE_CACHE, 'r') as f:\n",
    "            return json.load(f)\n",
    "    \n",
    "    api_key = os.environ.get('ANTHROPIC_API_KEY', '')\n",
    "    if not api_key:\n",
    "        print(\"⚠  ANTHROPIC_API_KEY not set. Using simulated sentiment for demo.\")\n",
    "        return simulate_llm_sentiment(tickers[:max_tickers])\n",
    "    \n",
    "    client = anthropic.Anthropic(api_key=api_key)\n",
    "    results = {}\n",
    "    \n",
    "    for ticker in tickers[:max_tickers]:\n",
    "        try:\n",
    "            tkr = yf.Ticker(ticker)\n",
    "            news = tkr.news\n",
    "            if not news:\n",
    "                continue\n",
    "            # Score each news item\n",
    "            scores = []\n",
    "            for item in news[:5]:  # last 5 news items\n",
    "                title   = item.get('title', '')\n",
    "                summary = item.get('summary', title)\n",
    "                score = get_llm_sentiment_score(ticker, f\"{title}. {summary}\", client)\n",
    "                score['published'] = item.get('providerPublishTime', 0)\n",
    "                scores.append(score)\n",
    "                time.sleep(0.1)  # rate limit\n",
    "            results[ticker] = scores\n",
    "        except Exception as e:\n",
    "            print(f\"  Error for {ticker}: {e}\")\n",
    "    \n",
    "    with open(CLAUDE_CACHE, 'w') as f:\n",
    "        json.dump(results, f)\n",
    "    return results\n",
    "\n",
    "\n",
    "def simulate_llm_sentiment(tickers, n_months=60, ic_target=0.04):\n",
    "    \"\"\"\n",
    "    Simulate LLM sentiment with realistic IC ~0.04 for IC analysis demo.\n",
    "    Replace with actual Claude API calls in production.\n",
    "    \"\"\"\n",
    "    np.random.seed(SEED + 1)\n",
    "    dates = pd.date_range(BACKTEST_START, END_DATE, freq='ME')\n",
    "    \n",
    "    # Simulate: sentiment correlated ~0.04 with future returns\n",
    "    sentiment_data = {}\n",
    "    for ticker in tickers:\n",
    "        if ticker not in returns_monthly_clean.columns:\n",
    "            continue\n",
    "        fwd = returns_monthly_clean[ticker].shift(-1).reindex(dates)\n",
    "        noise = pd.Series(np.random.randn(len(dates)), index=dates)\n",
    "        # IC ~0.04: small correlation with future returns\n",
    "        raw = ic_target * fwd.fillna(0) / fwd.fillna(0).std() + np.sqrt(1 - ic_target**2) * noise\n",
    "        sentiment_data[ticker] = raw\n",
    "    \n",
    "    return pd.DataFrame(sentiment_data)\n",
    "\n",
    "\n",
    "print(\"Fetching LLM sentiment...\")\n",
    "SENTIMENT_TICKERS = prices.columns[:50].tolist()\n",
    "\n",
    "# Check if API key available\n",
    "if os.environ.get('ANTHROPIC_API_KEY'):\n",
    "    sentiment_raw = fetch_news_and_score_sentiment(SENTIMENT_TICKERS, BACKTEST_START, END_DATE)\n",
    "    print(f\"Claude API sentiment: {len(sentiment_raw)} tickers scored\")\n",
    "else:\n",
    "    sentiment_panel = simulate_llm_sentiment(SENTIMENT_TICKERS)\n",
    "    print(f\"Simulated LLM sentiment panel: {sentiment_panel.shape}\")"
   ]
  },
