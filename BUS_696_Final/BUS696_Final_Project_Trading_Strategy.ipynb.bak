    "### Signal 4: Earnings Quality Composite — REFINED\n",
    "**Hypothesis:** Richardson et al. (2005) — high accruals predict poor future earnings;  \n",
    "buyback yield signals management confidence; analyst revision momentum captures PEAD.\n",
    "\n",
    "**Three sub-components (refined from Chapman FSM/DCF/TC course):**\n",
    "1. **Sloan Accruals** (FSM: Cash Flow Statement lecture): `(NI - CFO) / avg_assets` → negative = quality  \n",
    "2. **Buyback Yield** (DCF/Valuation lecture): `repurchases / market_cap` → high = shareholder-friendly (confidence signal)  \n",
    "3. **Normalized Earnings Ratio** (TC: Non-GAAP lecture): `Reported_EPS / (Reported_EPS + SBC + Restructuring + Amortization/Shares)` \n",
    "   - Ratio close to 1.0 = clean earnings (high quality)\n",
    "   - Ratio << 1.0 = heavy adjustments (lower quality, management masking issues)\n",
    "   - This captures the \"earnings quality\" that TC comps methodology identifies as critical"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Sub-component 4a: Sloan Accruals from yfinance quarterly financials ───────\n",
    "\n",
    "ACCRUALS_CACHE = 'accruals_cache.parquet'\n",
    "\n",
    "def fetch_accruals_data(tickers, cache_file=ACCRUALS_CACHE):\n",
    "    \"\"\"\n",
    "    Download quarterly CFO, Net Income, Total Assets from yfinance.\n",
    "    Compute Sloan Accruals = (NI - CFO) / avg_total_assets.\n",
    "    Negative = better earnings quality.\n",
    "    \n",
    "    ⚠️ CRITICAL: yfinance returns data indexed by QUARTER-END dates, not SEC filing dates.\n",
    "    SEC filing delays: 10-Q (45 days), 10-K (60 days) after quarter-end.\n",
    "    This function adds SEC_FILING_LAG to prevent look-ahead bias.\n",
    "    \"\"\"\n",
    "    if os.path.exists(cache_file):\n",
    "        print(\"Loading accruals cache...\")\n",
    "        return pd.read_parquet(cache_file)\n",
    "    \n",
    "    records = []\n",
    "    for i, ticker in enumerate(tickers):\n",
    "        if i % 25 == 0:\n",
    "            print(f\"  Fetching accruals: {i}/{len(tickers)}\")\n",
    "        try:\n",
    "            tkr = yf.Ticker(ticker)\n",
    "            cf  = tkr.quarterly_cashflow\n",
    "            inc = tkr.quarterly_income_stmt\n",
    "            bs  = tkr.quarterly_balance_sheet\n",
    "            \n",
    "            if cf is None or inc is None or bs is None:\n",
    "                continue\n",
    "            \n",
    "            # Extract rows\n",
    "            cfo_row    = 'Operating Cash Flow' if 'Operating Cash Flow' in cf.index else None\n",
    "            ni_row     = 'Net Income'           if 'Net Income'           in inc.index else None\n",
    "            asset_row  = 'Total Assets'         if 'Total Assets'         in bs.index else None\n",
    "            buyback_row = 'Repurchase Of Capital Stock' if 'Repurchase Of Capital Stock' in cf.index else None\n",
    "            \n",
    "            if not all([cfo_row, ni_row, asset_row]):\n",
    "                continue\n",
    "            \n",
    "            cfo    = cf.loc[cfo_row]\n",
    "            ni     = inc.loc[ni_row]\n",
    "            assets = bs.loc[asset_row]\n",
    "            \n",
    "            # Align dates\n",
    "            common_dates = cfo.index.intersection(ni.index).intersection(assets.index)\n",
    "            if len(common_dates) < 4:\n",
    "                continue\n",
    "            \n",
    "            cfo_s    = pd.to_numeric(cfo[common_dates], errors='coerce')\n",
    "            ni_s     = pd.to_numeric(ni[common_dates], errors='coerce')\n",
    "            assets_s = pd.to_numeric(assets[common_dates], errors='coerce')\n",
    "            \n",
    "            avg_assets = (assets_s + assets_s.shift(-1)) / 2\n",
    "            accruals   = (ni_s - cfo_s) / avg_assets.abs()\n",
    "            \n",
    "            # Buyback yield\n",
    "            if buyback_row and buyback_row in cf.index:\n",
    "                buybacks = pd.to_numeric(cf.loc[buyback_row, common_dates], errors='coerce').abs()\n",
    "                mktcap_approx = assets_s * 0.5  # rough proxy; replace with actual mkt cap\n",
    "                buyback_yield = buybacks.rolling(4).sum() / mktcap_approx.abs()\n",
    "            else:\n",
    "                buyback_yield = pd.Series(np.nan, index=common_dates)\n",
    "            \n",
    "            # ⚠️ CRITICAL FIX: Tag dates as QUARTER-END (need to add filing lag later)\n",
    "            for date in common_dates:\n",
    "                records.append({\n",
    "                    'ticker': ticker,\n",
    "                    'date': date,\n",
    "                    'is_quarter_end': True,  # yfinance returns quarter-end dates, not filing dates\n",
    "                    'accruals': accruals.get(date, np.nan),\n",
    "                    'buyback_yield': buyback_yield.get(date, np.nan)\n",
    "                })\n",
    "            \n",
    "            time.sleep(0.05)  # SEC rate limit\n",
    "            \n",
    "        except Exception as e:\n",
    "            continue\n",
    "    \n",
    "    df = pd.DataFrame(records)\n",
    "    if len(df) > 0:\n",
    "        df.to_parquet(cache_file)\n",
    "    return df\n",
    "\n",
    "# Fetch for a representative subset first\n",
    "ACCRUALS_TICKERS = prices.columns[:100].tolist()\n",
    "accruals_df = fetch_accruals_data(ACCRUALS_TICKERS)\n",
    "print(f\"Accruals data: {len(accruals_df)} quarterly observations\")\n",
    "if len(accruals_df) > 0:\n",
    "    print(accruals_df.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
