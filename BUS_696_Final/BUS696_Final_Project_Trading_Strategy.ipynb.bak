  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 5: ML Transaction Cost Model\n",
    "\n",
    "**From Week 9 lab:** Flat 10bps underestimates actual costs by 30–40% on average,  \n",
    "and by 5–8x during COVID. Using square root law + VIX-scaled spread."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Square root law market impact + bid-ask spread model ─────────────────────\n",
    "\n",
    "def estimate_transaction_costs(prices_monthly, returns_monthly, macro_monthly,\n",
    "                                aum_usd=1e8, top_n=TOP_N):\n",
    "    \"\"\"\n",
    "    ML transaction cost model:\n",
    "    Total cost = market_impact + spread_cost\n",
    "    \n",
    "    Market impact (square root law):\n",
    "      impact_bps = sigma * sqrt(Q / ADV) * 0.5 * 10000\n",
    "    \n",
    "    Spread cost (VIX-scaled):\n",
    "      spread_bps = base_spread * VIX_scalar\n",
    "      where base_spread ~ 2-5 bps for large-caps\n",
    "    \n",
    "    Returns monthly series of average cost per trade in bps.\n",
    "    \"\"\"\n",
    "    # Estimate ADV from 20-day volume (not available in free yfinance monthly)\n",
    "    # Use a simplified model based on daily volatility and VIX\n",
    "    \n",
    "    vol_monthly = returns_monthly.rolling(6).std()  # proxy for realized vol\n",
    "    \n",
    "    # Position size per stock\n",
    "    position_size = aum_usd / top_n\n",
    "    \n",
    "    # Average price per stock (proxy for market cap scale)\n",
    "    avg_price = prices_monthly.rolling(3).mean()\n",
    "    \n",
    "    costs = []\n",
    "    for date in wf_results.index:\n",
    "        if date not in vol_monthly.index:\n",
    "            continue\n",
    "        \n",
    "        vols = vol_monthly.loc[date].dropna()\n",
    "        prices_today = avg_price.loc[date].dropna()\n",
    "        \n",
    "        macro_date = macro_monthly.index[macro_monthly.index <= date]\n",
    "        vix = macro_monthly.loc[macro_date[-1], 'VIX'] if len(macro_date) > 0 else 20.0\n",
    "        \n",
    "        common = vols.index.intersection(prices_today.index)\n",
    "        \n",
    "        if len(common) == 0:\n",
    "            costs.append({'date': date, 'cost_bps': 15.0})\n",
    "            continue\n",
    "        \n",
    "        # Rough ADV estimate: assume $50B ADV for large-cap (conservative for 200-stock universe)\n",
    "        adv_est = 5e7  # $50M ADV per stock (conservative large-cap)\n",
    "        \n",
    "        sigma = vols[common].mean()\n",
    "        Q = position_size\n",
    "        \n",
    "        # Square root law impact\n",
    "        impact_bps = sigma * np.sqrt(Q / adv_est) * 0.5 * 10000\n",
    "        impact_bps = np.clip(impact_bps, 2, 100)  # bounds\n",
    "        \n",
    "        # VIX-scaled spread: base 2bps, scales with VIX\n",
    "        spread_bps = 2.0 * (vix / 20.0)\n",
    "        \n",
    "        # Total (roundtrip: entry + exit)\n",
    "        total_bps = (impact_bps + spread_bps) * 2\n",
    "        \n",
    "        costs.append({'date': date, 'cost_bps': total_bps})\n",
    "    \n",
    "    return pd.DataFrame(costs).set_index('date')\n",
    "\n",
    "cost_df = estimate_transaction_costs(prices_monthly, returns_monthly_clean, macro)\n",
    "print(f\"ML cost model statistics:\")\n",
    "print(cost_df['cost_bps'].describe())\n",
    "print(f\"\\nFlat 10bps assumption would miss {(cost_df['cost_bps'] > 10).mean():.1%} of months\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Apply transaction costs to portfolio returns ──────────────────────────────\n",
    "\n",
    "# Estimate monthly turnover (portfolio holds top_n stocks, ~50% turnover per Week 6 findings)\n",
    "ASSUMED_TURNOVER = 0.50\n",
    "\n",
    "# Merge costs with walk-forward results\n",
    "perf = wf_results[['port_return', 'gross_return', 'regime_scale', 'fold_ic']].copy()\n",
    "perf = perf.join(cost_df, how='left')\n",
    "perf['cost_bps'] = perf['cost_bps'].fillna(15.0)  # fill missing with 15bps default\n",
    "\n",
    "# Net return = gross return - (turnover × cost_bps / 10000)\n",
    "perf['cost_drag'] = ASSUMED_TURNOVER * perf['cost_bps'] / 10000\n",
    "perf['net_return'] = perf['gross_return'] * perf['regime_scale'] - perf['cost_drag']\n",
    "\n",
    "print(f\"Cost statistics:\")\n",
    "print(f\"  Avg ML cost (per-trade, bps): {perf['cost_bps'].mean():.1f}\")\n",
    "print(f\"  Avg cost drag (monthly):      {perf['cost_drag'].mean()*10000:.1f} bps\")\n",
    "print(f\"  Net vs Gross monthly return:  {perf['net_return'].mean():.4f} vs {perf['gross_return'].mean():.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 6: Kelly Position Sizing"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Kelly fraction from IC ────────────────────────────────────────────────────\n",
    "# f* = IC / (1 - IC²)  [Continuous ranking Kelly formula]\n",
    "# Use half-Kelly: f_kelly = f* × 0.5\n",
    "\n",
    "mean_ic = perf['fold_ic'].mean()\n",
    "std_ic  = perf['fold_ic'].std()\n",
    "\n",
    "# Full Kelly\n",
    "f_star = mean_ic / (1 - mean_ic**2) if abs(mean_ic) < 1 else 0.1\n",
    "# Half-Kelly (industry standard — reduces ruin risk)\n",
    "f_kelly = f_star * 0.5\n",
    "f_kelly_clipped = np.clip(f_kelly, 0.0, 0.30)  # cap at 30% for safety\n",
    "\n",
    "print(f\"Kelly Sizing Calibration\")\n",
    "print(f\"=\" * 40)\n",
    "print(f\"Mean OOS IC:          {mean_ic:.4f}\")\n",
    "print(f\"IC Std (uncertainty): {std_ic:.4f}\")\n",
    "print(f\"IC t-stat:            {mean_ic / (std_ic / np.sqrt(len(perf))):.2f}\")\n",
    "print(f\"Full Kelly fraction:  {f_star:.4f} ({f_star*100:.1f}%)\")\n",
    "print(f\"Half-Kelly fraction:  {f_kelly:.4f} ({f_kelly*100:.1f}%)\")\n",
    "print(f\"Applied fraction:     {f_kelly_clipped:.4f} ({f_kelly_clipped*100:.1f}%)\")\n",
    "print()\n",
    "if mean_ic < 0.02:\n",
    "    print(\"⚠  WARNING: IC < 0.02. Edge is weak — half-Kelly wisely limits exposure.\")\n",
    "elif mean_ic > 0.10:\n",
    "    print(\"✓  IC > 0.10 is strong. Verify no look-ahead bias in signal construction.\")\n",
    "else:\n",
    "    print(\"✓  IC in normal range (0.02–0.10) for institutional cross-sectional strategies.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Build baselines for comparison ────────────────────────────────────────────\n",
    "\n",
    "# Baseline 1: Equal-weight buy-and-hold of universe\n",
    "ew_returns = returns_monthly_clean.loc[perf.index].mean(axis=1)\n",
    "\n",
    "# Baseline 2: Pure 12-1 momentum sort (no ML)\n",
    "def momentum_only_portfolio(sig_momentum_z, returns_monthly, top_n=TOP_N):\n",
    "    mom_returns = []\n",
    "    for date in perf.index:\n",
    "        if date not in sig_momentum_z.index:\n",
    "            continue\n",
    "        ranked = sig_momentum_z.loc[date].dropna().sort_values(ascending=False)\n",
    "        top_tickers = ranked.head(top_n).index\n",
    "        if date in returns_monthly.index:\n",
    "            fwd_date_idx = returns_monthly.index.get_loc(date)\n",
    "            if fwd_date_idx + 1 < len(returns_monthly.index):\n",
    "                fwd_date = returns_monthly.index[fwd_date_idx + 1]\n",
    "                ret = returns_monthly.loc[fwd_date, top_tickers].mean()\n",
    "                mom_returns.append({'date': date, 'return': ret})\n",
    "    return pd.DataFrame(mom_returns).set_index('date')['return'] if mom_returns else pd.Series()\n",
    "\n",
    "mom_only_returns = momentum_only_portfolio(sig_momentum_z, returns_monthly_clean)\n",
    "\n",
    "print(f\"Baselines constructed:\")\n",
    "print(f\"  Equal-weight universe:  {len(ew_returns)} months\")\n",
    "print(f\"  Pure momentum sort:     {len(mom_only_returns)} months\")"
   ]
  },
