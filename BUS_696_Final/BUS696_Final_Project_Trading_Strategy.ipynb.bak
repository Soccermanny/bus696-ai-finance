    "# ── 1b. Download price data ───────────────────────────────────────────────────\n",
    "# Use a manageable subset for compute time; expand to full 500 for final run\n",
    "UNIVERSE = sp500_tickers[:250]   # top 250 by index weight order\n",
    "\n",
    "CACHE_FILE = 'price_data_cache.parquet'\n",
    "\n",
    "if os.path.exists(CACHE_FILE):\n",
    "    print(\"Loading cached price data...\")\n",
    "    prices_raw = pd.read_parquet(CACHE_FILE)\n",
    "else:\n",
    "    print(f\"Downloading price data for {len(UNIVERSE)} tickers...\")\n",
    "    prices_raw = yf.download(\n",
    "        UNIVERSE,\n",
    "        start=START_DATE,\n",
    "        end=END_DATE,\n",
    "        auto_adjust=True,\n",
    "        progress=True\n",
    "    )['Close']\n",
    "    prices_raw.to_parquet(CACHE_FILE)\n",
    "    print(\"Saved to cache.\")\n",
    "\n",
    "# Drop tickers with too many NaNs (less than 80% coverage)\n",
    "coverage = prices_raw.notna().mean()\n",
    "prices = prices_raw.loc[:, coverage >= 0.80].copy()\n",
    "print(f\"Price data shape after coverage filter: {prices.shape}\")\n",
    "print(f\"Date range: {prices.index[0].date()} → {prices.index[-1].date()}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "73624629",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── 1c. Resample to monthly (end-of-month) and compute returns ────────────────\n",
    "prices_monthly = prices.resample('ME').last()\n",
    "returns_monthly = prices_monthly.pct_change()  # forward 1-month return\n",
    "\n",
    "# Winsorize monthly returns at 1%/99% to reduce micro-cap noise\n",
    "def winsorize(df, lower=0.01, upper=0.99):\n",
    "    lo = df.quantile(lower, axis=1)\n",
    "    hi = df.quantile(upper, axis=1)\n",
    "    return df.clip(lo, hi, axis=0)\n",
    "\n",
    "returns_monthly_clean = winsorize(returns_monthly)\n",
    "\n",
    "print(f\"Monthly returns shape: {returns_monthly_clean.shape}\")\n",
    "print(f\"Avg monthly return (all tickers): {returns_monthly_clean.stack().mean():.4f}\")"
   ]
  },
