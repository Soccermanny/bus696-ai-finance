    "ax.plot(cumret_strat.index, cumret_strat, label='XGBoost (Net)', color='steelblue', linewidth=2)\n",
    "ax.plot(cumret_ew.index,    cumret_ew,    label='Equal-Weight',  color='gray',      linewidth=1.5, linestyle='--')\n",
    "ax.plot(cumret_mom.index,   cumret_mom,   label='Momentum Only', color='darkorange', linewidth=1.5, linestyle=':')\n",
    "ax.set_title('Cumulative Returns (OOS Only)'); ax.legend(); ax.set_ylabel('Growth of $1')\n",
    "\n",
    "# Panel 2: Drawdown\n",
