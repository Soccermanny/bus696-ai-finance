    "    print()\n",
    "    \n",
    "    if mean_ic_llm > 0.03:\n",
    "        print(\"✓ LLM sentiment adds value (IC > 0.03 threshold)\")\n",
    "        print(\"  BONUS ALT DATA: Signal qualifies for +10 points\")\n",
    "    else:\n",
    "        print(\"⚠  IC < 0.03 — LLM sentiment marginal. Show subperiod analysis.\")\n",
    "\n",
    "    # IC rolling plot\n",
    "    fig, ax = plt.subplots(figsize=(12, 4))\n",
    "    ic_llm['IC'].rolling(12).mean().plot(ax=ax, color='purple', linewidth=2, label='12m Rolling IC')\n",
    "    ic_llm['IC'].plot(ax=ax, color='purple', alpha=0.3, linewidth=0.8)\n",
    "    ax.axhline(0, color='black', linewidth=0.8)\n",
    "    ax.axhline(0.03, color='green', linestyle='--', alpha=0.7, label='IC=0.03 threshold')\n",
    "    ax.set_title('LLM Sentiment IC Over Time')\n",
    "    ax.legend()\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('llm_sentiment_ic.png', dpi=150, bbox_inches='tight')\n",
    "    plt.show()"
   ]
